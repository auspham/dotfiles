// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Editor",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-b": "workspace::ToggleRightDock",
      "ctrl-shift-b": "workspace::ToggleLeftDock",
      "alt-s alt-z": "workspace::ToggleZoom",
      "ctrl-v": "editor::Paste",
      "ctrl-c": "editor::Copy",
      "ctrl-f": "buffer_search::Deploy",
      "ctrl-a": "editor::SelectAll",
      "ctrl-s": "workspace::Save",
      "ctrl-alt-l": "editor::ToggleLineNumbers",
      "ctrl-k ctrl-w": "pane::CloseAllItems"
    },
  },
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      "ctrl-`": "workspace::ToggleBottomDock",
      "space p": "editor::Format",
      "space space": "file_finder::Toggle",
      "space v": "pane::SplitVertical",
      "space w": "pane::CloseActiveItem",
      "ctrl-w": "pane::CloseActiveItem",
      "space h": "pane::SplitHorizontal",
      "space l": "workspace::ActivatePreviousPane",
      "space e": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "j k": "vim::NormalBefore",
      "alt-h": "vim::Left",
      "alt-l": "vim::Right",
      "alt-j": "vim::Down",
      "alt-k": "vim::Up",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "shift-j": "editor::MoveLineDown",
      "shift-k": "editor::MoveLineUp",
    },
  },
  {
    "context": "ProjectPanel",
    "bindings": {
      "ctrl-shift-b": "workspace::ToggleLeftDock",
      "space e": "project_panel::ToggleFocus",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-/": "workspace::ToggleBottomDock",
      "alt-s alt-z": "workspace::ToggleZoom",
    },
  },
  {
    "context": "Dock",

    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-j": "workspace::ActivatePaneDown",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-shift-b": "workspace::ToggleLeftDock",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-b": null,
    },
  },
  {
    "context": "TabSwitcher",
    "bindings": {
      "ctrl-k": "menu::SelectPrevious",
      "ctrl-j": "menu::SelectNext",
      "ctrl-w": "tab_switcher::CloseSelectedItem",
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-shift-t": [
        "pane::CloseOtherItems",
        {
          "close_pinned": false
        }
      ]
    }
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-alt-t": null
    }
  }
]
