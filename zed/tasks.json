[
  {
    "label": "start lazygit",
    "command": "lazygit",
    "args": ["-p", "$ZED_WORKTREE_ROOT"],
    "allow_concurrent_runs": true,
    "reveal": "always",
    "hide": "on_success",
    "shell": {
      "program": "sh"
    }
  },
  {
    "label": "start lazygit file log",
    "command": "lazygit",
    "args": ["-f", "$ZED_RELATIVE_FILE"],
    "allow_concurrent_runs": true,
    "reveal": "always",
    "hide": "on_success",
    "shell": {
      "program": "sh"
    }
  }
]
